# ============================================================
# SAMPA TERRA CRM — Variáveis de Ambiente
# Copie este arquivo para .env (Prisma) e .env.local (Next.js)
# e preencha com as credenciais do projeto Supabase da Sampa Terra.
# NÃO reutilize as credenciais do projeto da Obraria.
# ============================================================

# --- Banco de dados (Prisma + Supabase Postgres) ---
DATABASE_URL="postgresql://postgres:[PASSWORD]@[HOST]:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres:[PASSWORD]@[HOST]:5432/postgres"

# --- Supabase (client + storage) ---
NEXT_PUBLIC_SUPABASE_URL="https://[PROJECT-REF].supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY=""
SUPABASE_SERVICE_ROLE_KEY=""

# --- NextAuth ---
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET=""

# --- Resend (envio de e-mail) ---
RESEND_API_KEY=""
RESEND_FROM="Sampa Terra CRM <noreply@sampaterra.com.br>"
